{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\mssqllocaldb;Database=CyberCordDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "TokenIssuer": "CyberCord.Api",
    "TokenAudience": "CyberCord.Api-Users",
    "ExpirationTimeMinutes": 60
  },
  "AllowedHosts": "*",
  "ActivationCode": {
    "ActivationCodeLifeTimeInMinutes": 10
  },
  "EmailSender": {
    "SourceEmailAddress": "ccauth.noreply@gmail.com",
    "EmailHost": "smtp.gmail.com",
    "EmailUsername": "Cyber Cord"
  },
  "PasswordOptions": {
    "SaltLength": 16,
    "HashLength": 20,
    "Iterations": 4,
    "Lanes": 4,
    "Threads": 2,
    "MemoryCost":  65536
  }
}
