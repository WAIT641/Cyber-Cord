@using Radzen.Blazor

<h3 class="text_style">PasswordConfirmationDialog</h3>

<div id="form">
    <h3 class="text_style">Settings</h3>

    <RadzenTemplateForm Data="Model">
        <label for="name" class="label_style text_style">Password</label>
        <br />
        <RadzenPassword id="password" Name="password" Placeholder="Password" class="input_style" @bind-Value="Model" />
    </RadzenTemplateForm>
</div>
