@using Radzen.Blazor

<div id="form">
    <h3 class="text_style">Modify Chat</h3>

    <RadzenTemplateForm Data="Model">
        <label for="name" class="label_style text_style">Name</label>
        <br />
        <RadzenTextBox id="name" Name="name" Placeholder="Channel name" class="input_style" @bind-Value="Model.Name" />
    </RadzenTemplateForm>
</div>