@using Radzen.Blazor

<div id="form">
    <h3 class="text_style">Settings</h3>

    <RadzenTemplateForm Data="Model">
        <label for="name" class="label_style text_style">Name</label>
        <br />
        <RadzenTextBox id="name" Name="name" Placeholder="Channel name" class="input_style" @bind-Value="Model.Name" />
        <br />

        <label for="description" class="label_style text_style">Description</label>
        <br />
        <RadzenTextArea id="description" Name="descriptiion" Placeholder="Channel description" class="text_area" @bind-Value="Model.Description" />
    </RadzenTemplateForm>
</div>
